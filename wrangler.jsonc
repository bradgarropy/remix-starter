{
    "$schema": "node_modules/wrangler/config-schema.json",
    "name": "remix-starter",
    "compatibility_date": "2025-10-08",
    "compatibility_flags": ["nodejs_compat"],
    "main": "./src/worker.ts",
    "assets": {
        "directory": "./build/client",
    },
    "observability": {
        "enabled": true,
    },
    "upload_source_maps": true,
    "version_metadata": {
        "binding": "CF_VERSION_METADATA",
    },
}
