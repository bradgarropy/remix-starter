{
    "$schema": "node_modules/wrangler/config-schema.json",
    "name": "react-router-starter",
    "compatibility_date": "2025-10-08",
    "compatibility_flags": ["nodejs_compat"],
    "keep_vars": true,
    "main": "./src/worker.ts",
    "dev": {
        "port": 3000,
    },
    "observability": {
        "enabled": true,
    },
    "upload_source_maps": true,
    "version_metadata": {
        "binding": "CF_VERSION_METADATA",
    },
}
