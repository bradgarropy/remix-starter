{
    "name": "react-router-starter",
    "version": "5.0.0",
    "description": "📍 react router starter",
    "type": "module",
    "keywords": [
        "typescript",
        "react",
        "eslint",
        "prettier",
        "vitest",
        "cloudflare",
        "remix",
        "remix-stack",
        "tailwind",
        "hacktoberfest"
    ],
    "homepage": "https://github.com/bradgarropy/react-router-starter",
    "bugs": {
        "url": "https://github.com/bradgarropy/react-router-starter/issues"
    },
    "license": "MIT",
    "author": {
        "name": "Brad Garropy",
        "email": "bradgarropy@gmail.com",
        "url": "https://bradgarropy.com"
    },
    "repository": {
        "type": "git",
        "url": "https://github.com/bradgarropy/react-router-starter"
    },
    "scripts": {
        "dev": "remix vite:dev",
        "build": "remix vite:build",
        "start": "wrangler dev",
        "preview": "npm run build && wrangler dev",
        "deploy": "wrangler deploy",
        "typegen": "wrangler types",
        "lint": "eslint .",
        "lint:fix": "eslint . --fix",
        "format": "prettier --check .",
        "format:fix": "prettier --write .",
        "typecheck": "wrangler types && tsc",
        "test": "vitest --coverage",
        "test:ui": "vitest --coverage --watch --ui",
        "test:watch": "vitest --coverage --watch",
        "test:e2e": "playwright test",
        "test:e2e:ui": "playwright test --ui",
        "contributors": "all-contributors generate",
        "new": "plop"
    },
    "dependencies": {
        "@remix-run/cloudflare": "^2.17.2",
        "@remix-run/react": "^2.2.0",
        "@sentry/remix": "^10.53.0",
        "isbot": "^5.1.1",
        "react": "^19.0.0",
        "react-dom": "^19.0.0"
    },
    "devDependencies": {
        "@bradgarropy/eslint-config": "^3.0.0",
        "@bradgarropy/plop-generator-remix-route": "^1.0.0",
        "@playwright/test": "^1.48.0",
        "@remix-run/dev": "^2.2.0",
        "@remix-run/route-config": "^2.15.1",
        "@sentry/vite-plugin": "^5.3.0",
        "@tailwindcss/vite": "^4.0.0",
        "@testing-library/dom": "^10.4.0",
        "@testing-library/jest-dom": "^6.1.4",
        "@testing-library/react": "^16.0.0",
        "@testing-library/user-event": "^14.4.3",
        "@types/node": "^25.7.0",
        "@types/react": "^19.0.1",
        "@types/react-dom": "^19.0.2",
        "@vitejs/plugin-react": "^6.0.1",
        "@vitest/coverage-v8": "^4.1.6",
        "@vitest/ui": "^4.1.6",
        "all-contributors-cli": "^6.20.0",
        "autoprefixer": "^10.4.8",
        "jsdom": "^29.1.1",
        "plop": "^4.0.0",
        "prettier": "^3.1.0",
        "prettier-plugin-tailwindcss": "^0.8.0",
        "remix-development-tools": "^4.7.7",
        "tailwindcss": "^4.0.0",
        "typescript": "^6.0.3",
        "vite": "^8.0.12",
        "vitest": "^4.1.6",
        "wrangler": "^4.0.0"
    },
    "engines": {
        "node": ">=20"
    },
    "sideEffects": false
}
